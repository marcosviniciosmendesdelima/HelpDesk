{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "chamados_route": {
        "ClusterId": "python_api_cluster",
        "Match": {
          "Path": "/api/v1/chamados/{**remainder}"
        }
      }
    },
    "Clusters": {
      "python_api_cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5000/"
          }
        }
      }
    }
  }
}