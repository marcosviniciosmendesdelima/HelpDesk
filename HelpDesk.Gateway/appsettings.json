{
  "ReverseProxy": {
    "Routes": {
      "tickets_route": {
        "ClusterId": "tickets_cluster",
        "Match": {
          "Path": "/api/v1/tickets/{**catch-all}"
        }
      },
      "signalr_route": {
        "ClusterId": "signalr_cluster",
        "Match": {
          "Path": "/hubs/tickets/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "tickets_cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://api-helpdesk:8000/"
          }
        }
      },
      "signalr_cluster": {
        "SessionAffinity": {
          "Enabled": true,
          "FailurePolicy": "Return503Error",
          "AffinityKeyName": ".AspNetCore.Cookie"
        },
        "Destinations": {
          "destination1": {
            "Address": "http://api-helpdesk:8000/"
          }
        },
        "HttpRequest": {
          "ActivityTimeout": "00:01:00"
        }
      }
    }
  }
}